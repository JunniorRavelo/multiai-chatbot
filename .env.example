# Chatbot Plugin WP — referencia de configuración
# WordPress no usa .env nativamente. Configura en:
#   1) Admin → Chatbot → Seguridad / Modelo IA
#   2) wp-config.php con las constantes CHATBOT_* (recomendado en producción)

## CHAT BOT - IA
# Gemini (server-side only)
# GEMINI_API_KEY          → CHATBOT_GEMINI_API_KEY en wp-config.php
# GEMINI_MODEL            → pestaña Modelo IA o CHATBOT_GEMINI_MODEL
# GEMINI_MODEL_CANDIDATES → pestaña Modelo IA o CHATBOT_GEMINI_MODEL_CANDIDATES
GEMINI_API_KEY=.........
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MODEL_CANDIDATES=gemini-3-flash,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-tts,gemini-2.5-flash-tts
CHAT_STREAMING_ENABLED=true

# Allowed origins for chatbot endpoint (comma-separated)
CHAT_ALLOWED_ORIGINS=https://jsravelo.misistema.com.co,https://misistema.com.co,http://localhost:3000,http://127.0.0.1:3000

# Chatbot cache and telemetry
CHAT_CACHE_TTL_SECONDS=1800
CHAT_TELEMETRY_LOG_PATH=./telemetry.log

# Chatbot rate limits
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_DAY=30
CHAT_RATE_LIMIT_MODEL_PER_MINUTE=6
CHAT_RATE_LIMIT_MODEL_PER_DAY=24
CHAT_RATE_LIMIT_SOFT_THRESHOLD=0.8
CHAT_IP_SUSPEND_AFTER_VIOLATIONS=3
CHAT_IP_SUSPEND_SECONDS=900

# Internal URL used by stream to call /chat without public proxy hops
INTERNAL_CHAT_BASE_URL=http://127.0.0.1:3000

# --- Mapeo a wp-config.php (opcional) ---
