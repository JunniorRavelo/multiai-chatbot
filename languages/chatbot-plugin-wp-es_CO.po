msgid "Origins and access"
msgstr "Orígenes y acceso"

#: includes/admin-settings.php:1015
msgid "Control which domains can call the chat endpoint."
msgstr "Controle qué dominios pueden llamar al endpoint del chat."

#: includes/admin-settings.php:1020
msgid "Allowed origins"
msgstr "Orígenes permitidos"

#. translators: %s: site home URL
#: includes/admin-settings.php:1027
#, php-format
msgid "Comma-separated URLs. Empty = this site only (%s). Equivalent to CHAT_ALLOWED_ORIGINS."
msgstr "URLs separadas por comas. Vacío = solo este sitio (%s). Equivalente a "
"CHAT_ALLOWED_ORIGINS."

#: includes/admin-settings.php:1035
msgid "Internal chat URL"
msgstr "URL interna del chat"

#: includes/admin-settings.php:1038
msgid "Optional. Leave empty in most installations. If set, use a local URL (e.g. http://127.0.0.1); do not use the public URL with Cloudflare."
msgstr "Opcional. Déjelo vacío en la mayoría de instalaciones. Si lo define, u"
"se una URL local (p. ej. http://127.0.0.1); no use la URL pública con "
"Cloudflare."

#: includes/admin-settings.php:1046
msgid "Cache and telemetry"
msgstr "Caché y telemetría"

#: includes/admin-settings.php:1047
msgid "Reduce repeated model calls and optionally log events to a file."
msgstr "Reduzca llamadas repetidas al modelo y, opcionalmente, registre evento"
"s en un archivo."

#: includes/admin-settings.php:1052
msgid "Cache TTL (seconds)"
msgstr "TTL de caché (segundos)"

#: includes/admin-settings.php:1055
msgid "0 = disable cache. Equivalent to CHAT_CACHE_TTL_SECONDS."
msgstr "0 = desactivar caché. Equivalente a CHAT_CACHE_TTL_SECONDS."

#: includes/admin-settings.php:1059
msgid "Telemetry log path"
msgstr "Ruta del registro de telemetría"

#: includes/admin-settings.php:1062
msgid "Optional. In addition to the database, write events to this file. Equivalent to CHAT_TELEMETRY_LOG_PATH."
msgstr "Opcional. Además de la base de datos, escriba eventos en este archivo."
" Equivalente a CHAT_TELEMETRY_LOG_PATH."

#: includes/admin-settings.php:1066
msgid "History retention (days)"
msgstr "Retención del historial (días)"

#: includes/admin-settings.php:1069
msgid "0 = keep indefinitely. Older conversations are purged automatically each day."
msgstr "0 = conservar indefinidamente. Las conversaciones antiguas se purgan a"
"utomáticamente cada día."

#: includes/admin-settings.php:1073
msgid "Telemetry retention (days)"
msgstr "Retención de telemetría (días)"

#: includes/admin-settings.php:1076
msgid "0 = keep indefinitely. Older statistics events are purged automatically each day."
msgstr "0 = conservar indefinidamente. Los eventos de estadísticas antiguos se"
" purgan automáticamente cada día."

#: includes/admin-settings.php:1084
msgid "Rate limits"
msgstr "Límites de tasa"

#: includes/admin-settings.php:1085
msgid "Protect the endpoint and AI provider quota from abuse."
msgstr "Proteja el endpoint y la cuota del proveedor de IA del abuso."

#: includes/admin-settings.php:1090
msgid "Per IP / minute"
msgstr "Por IP / minuto"

#: includes/admin-settings.php:1093
msgid "CHAT_RATE_LIMIT_PER_MINUTE"
msgstr "CHAT_RATE_LIMIT_PER_MINUTE"

#: includes/admin-settings.php:1097
msgid "Per IP / day"
msgstr "Por IP / día"

#: includes/admin-settings.php:1100
msgid "CHAT_RATE_LIMIT_PER_DAY"
msgstr "CHAT_RATE_LIMIT_PER_DAY"

#: includes/admin-settings.php:1104
