msgstr "Modelo / día (global)"

#: includes/admin-settings.php:1114
msgid "CHAT_RATE_LIMIT_MODEL_PER_DAY"
msgstr "CHAT_RATE_LIMIT_MODEL_PER_DAY"

#: includes/admin-settings.php:1118
