msgid "Widget header"
msgstr "Cabecera del widget"

#: includes/admin-settings.php:987
msgid "Title and subtitle shown in the chat top bar."
msgstr "Título y subtítulo mostrados en la barra superior del chat."

#: includes/admin-settings.php:992
msgid "Widget title"
msgstr "Título del widget"

#: includes/admin-settings.php:998
msgid "Subtitle"
msgstr "Subtítulo"

